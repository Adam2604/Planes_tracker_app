<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/card_background"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:gravity="center_vertical">

    <!-- Time -->
    <TextView
        android:id="@+id/flightTime"
        android:layout_width="50dp"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <!-- Model + ICAO -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/flightModel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/flightIcao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:background="@drawable/icao_tag_background"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="1dp"
            android:paddingBottom="1dp"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Distance -->
    <TextView
        android:id="@+id/flightDist"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:textColor="@color/accent_green"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- Route button -->
    <Button
        android:id="@+id/routeBtn"
        android:layout_width="42dp"
        android:layout_height="36dp"
        android:layout_marginStart="8dp"
        android:backgroundTint="@color/accent_orange"
        android:text="🗺️"
        android:textSize="14sp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:padding="0dp"
        android:visibility="gone" />

</LinearLayout>
